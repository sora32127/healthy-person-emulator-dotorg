generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model DimPosts {
  postId                Int                     @id @default(autoincrement()) @map("post_id")
  postAuthorIPHash      String                  @map("post_author_ip_hash")
  postDateJst           String                  @default(dbgenerated("(datetime('now', 'localtime'))")) @map("post_date_jst")
  postDateGmt           String                  @default(dbgenerated("(datetime('now'))")) @map("post_date_gmt")
  postContent           String                  @map("post_content")
  postTitle             String                  @map("post_title")
  commentStatus         String                  @map("comment_status")
  countLikes            Int                     @default(0) @map("count_likes")
  countDislikes         Int                     @default(0) @map("count_dislikes")
  uuid                  String                  @default(dbgenerated("(lower(hex(randomblob(16))))")) @map("uuid")
  ogpImageUrl           String?                 @map("ogp_image_url")
  isSnsShared           Int                     @default(0) @map("is_sns_shared")
  isSnsPickuped         Int                     @default(0) @map("is_sns_pickuped")
  dimComments           DimComments[]
  fctPostEditHistory    FctPostEditHistory[]
  fctPostVoteHistory    FctPostVoteHistory[]
  nowEditingPages       NowEditingPages?
  relPostTags           RelPostTags[]
  FctCommentVoteHistory FctCommentVoteHistory[]

  @@map("dim_posts")
}

model DimComments {
  commentId             Int                     @id @default(autoincrement()) @map("comment_id")
  postId                Int                     @map("post_id")
  commentAuthor         String                  @default("Anonymous") @map("comment_author")
  commentAuthorIpHash   String                  @default("") @map("comment_author_ip_hash")
  commentDateJst        String                  @default(dbgenerated("(datetime('now', 'localtime'))")) @map("comment_date_jst")
  commentDateGmt        String                  @default(dbgenerated("(datetime('now'))")) @map("comment_date_gmt")
  commentContent        String                  @map("comment_content")
  commentParent         Int                     @map("comment_parent")
  uuid                  String                  @default(dbgenerated("(lower(hex(randomblob(16))))")) @map("uuid")
  dimPosts              DimPosts                @relation(fields: [postId], references: [postId], onDelete: Cascade)
  fctCommentVoteHistory FctCommentVoteHistory[]

  @@map("dim_comments")
}

model DimTags {
  tagId       Int           @id @default(autoincrement()) @map("tag_id")
  tagName     String        @map("tag_name")
  relPostTags RelPostTags[]

  @@map("dim_tags")
}

model FctCommentVoteHistory {
  commentVoteId      Int         @id @default(autoincrement()) @map("comment_vote_id")
  voteUserIpHash     String      @map("vote_user_ip_hash")
  commentId          Int         @map("comment_id")
  voteType           Int         @map("vote_type")
  postId             Int         @map("post_id")
  commentVoteDateJst String      @default(dbgenerated("(datetime('now', 'localtime'))")) @map("comment_vote_date_jst")
  commentVoteDateUtc String      @default(dbgenerated("(datetime('now'))")) @map("comment_vote_date_utc")
  dimComments        DimComments @relation(fields: [commentId], references: [commentId], onDelete: Cascade)
  dimPosts           DimPosts    @relation(fields: [postId], references: [postId], onDelete: Cascade)

  @@map("fct_comment_vote_history")
}

model FctPostEditHistory {
  postEditId            Int      @id @default(autoincrement()) @map("post_edit_id")
  postId                Int      @map("post_id")
  postRevisionNumber    Int      @map("post_revision_number")
  postEditDateJst       String   @default(dbgenerated("(datetime('now', 'localtime'))")) @map("post_edit_date_jst")
  postEditDateGmt       String   @default(dbgenerated("(datetime('now'))")) @map("post_edit_date_gmt")
  postTitleBeforeEdit   String   @map("post_title_before_edit")
  postTitleAfterEdit    String   @map("post_title_after_edit")
  postContentBeforeEdit String   @map("post_content_before_edit")
  postContentAfterEdit  String   @map("post_content_after_edit")
  editorUserId          String?  @map("editor_user_id")
  dimPosts              DimPosts @relation(fields: [postId], references: [postId], onDelete: Cascade)

  @@map("fct_post_edit_history")
}

model FctPostVoteHistory {
  postVoteId     Int      @id @default(autoincrement()) @map("post_vote_id")
  voteDateGmt    DateTime   @default(dbgenerated("(datetime('now'))")) @map("vote_date_gmt")
  voteUserIpHash String   @map("vote_user_ip_hash")
  postId         Int      @map("post_id")
  voteTypeInt    Int      @map("vote_type_int")
  voteDateJst    String   @default(dbgenerated("(datetime('now', 'localtime'))")) @map("vote_date_jst")
  dimPosts       DimPosts @relation(fields: [postId], references: [postId], onDelete: Cascade)

  @@map("fct_post_vote_history")
}

model NowEditingPages {
  postId             Int      @id @map("post_id")
  lastHeartBeatAtUTC String   @default(dbgenerated("(datetime('now'))")) @map("last_heart_beat_at_utc")
  userId             String   @map("user_id")
  dimPosts           DimPosts @relation(fields: [postId], references: [postId], onDelete: Cascade)

  @@map("now_editing_pages")
}

model RelPostTags {
  relPostTagsId Int      @id @default(autoincrement()) @map("rel_post_tags_id")
  postId        Int      @map("post_id")
  tagId         Int      @map("tag_id")
  dimPosts      DimPosts @relation(fields: [postId], references: [postId], onDelete: Cascade)
  dimTags       DimTags  @relation(fields: [tagId], references: [tagId], onDelete: Cascade)

  @@map("rel_post_tags")
}
