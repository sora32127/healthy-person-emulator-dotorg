{
  "enabledPlugins": {
    "frontend-design@claude-plugins-official": true,
    "feature-dev@claude-plugins-official": true,
    "ui-ux-pro-max@ui-ux-pro-max-skill": true
  },
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/session-start-branch.sh",
            "timeout": 30,
            "statusMessage": "mainを最新化してブランチを作成中..."
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/check-plan-files.sh",
            "timeout": 10,
            "statusMessage": "プランファイルの確認中..."
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/check-pr-commits.sh",
            "timeout": 15,
            "statusMessage": "PRコミットの検証中..."
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/check-diff-size.sh",
            "timeout": 10,
            "statusMessage": "変更行数チェック中..."
          }
        ]
      },
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/lint-and-format.sh",
            "timeout": 30,
            "statusMessage": "format 実行中..."
          }
        ]
      },
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/terraform-fmt.sh",
            "timeout": 30,
            "statusMessage": "terraform fmt 実行中..."
          }
        ]
      }
    ]
  }
}
